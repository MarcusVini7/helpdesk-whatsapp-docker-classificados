# =========================================================
# Help Desk WhatsApp com IA - ambiente Docker local
# Copie este arquivo para .env antes de subir:
# cp .env.example .env
# =========================================================

# App
NODE_ENV=development
SERVER_PORT=3001
CLIENT_PORT=5173
CLIENT_URL=http://localhost:5173
JWT_SECRET=troque-esta-chave-jwt-por-uma-chave-forte
JWT_EXPIRES_IN=8h

# Admin inicial criado no primeiro start
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin123

# MySQL do Help Desk
MYSQL_ROOT_PASSWORD=root123
MYSQL_PORT=3307
DB_HOST=mysql
DB_PORT=3306
DB_USER=helpdesk
DB_PASSWORD=helpdesk123
DB_NAME=helpdesk_whatsapp

# Adminer - painel web do banco
ADMINER_PORT=8081

# IA
# ollama = IA local em container Docker
# openai = API externa da OpenAI
AI_PROVIDER=ollama
AI_SYSTEM_PROMPT=Você é um atendente de help desk. Responda com clareza, objetividade e peça dados técnicos quando necessário.
AUTO_AI_REPLY=false

# IA local com Ollama
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# IA via OpenAI, se preferir usar API externa
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# WhatsApp / Evolution API local em container
EVOLUTION_IMAGE=evoapicloud/evolution-api:v2.1.1
EVOLUTION_PORT=8080
EVOLUTION_SERVER_URL=http://localhost:8080
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=change-me
EVOLUTION_INSTANCE=helpdesk
WHATSAPP_SEND_ENABLED=false


# Classificados / AMD2 integrado
# O script ./scripts/baixar-amd2.sh baixa o projeto https://github.com/MarcusVini7/amd2 para ./amd2
CLASSIFICADOS_PORT=8090
CLASSIFICADOS_PUBLIC_URL=http://localhost:8090
AMD2_DB_PASS=asterisk
AMD2_JWT_SECRET=dev_secret_change_me
AMD2_ADMIN_USER=admin
AMD2_ADMIN_PASS=6FAH4YoVwefWbMZHQFLp
AMD2_AMI_USER=amdapi
AMD2_AMI_SECRET=amdapi123
AMD2_CRON_TOKEN=
AMD2_SIP_PORT=5070
AMD2_AMI_PORT=5039
AMD2_RTP_RANGE=31000-31100
